od options, and heavily influenced by social content."]}],["$","p","3",{"className":"article-p","children":["Jin's target was simple: ",["$","strong","1",{"children":"50 new customers in the first month, at a cost they could justify against average ticket value of $32"}],"."]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18"]}]]}]}]}],"$L19","$L1a","$L1b"],["$L1c","$L1d","$L1e"],"$L1f"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"jP0DLMf4-wLgFORDq_Yoq"}
