24:["$","div",null,{"className":"legal-table-wrap","children":["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"Violation Severity"}],["$","th",null,{"children":"Typical Action"}],["$","th",null,{"children":"Appeal Window"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":"Minor (first offense, no harm)"}],["$","td",null,{"children":"Written warning; content removal request"}],["$","td",null,{"children":"Not applicable"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"Moderate (repeat offense or material harm to one party)"}],["$","td",null,{"children":"Temporary suspension (7–30 days); campaign disqualification; payout hold"}],["$","td",null,{"children":"14 days"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"Severe (fraud, harassment, illegal content)"}],["$","td",null,{"children":"Permanent account termination; payout clawback; referral to law enforcement"}],["$","td",null,{"children":"14 days"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"Critical (systematic fraud, platform attack)"}],["$","td",null,{"children":"Immediate permanent ban; civil and/or criminal legal action; public disclosure where required by law"}],["$","td",null,{"children":"None"}]]}]]}]]}]}]
