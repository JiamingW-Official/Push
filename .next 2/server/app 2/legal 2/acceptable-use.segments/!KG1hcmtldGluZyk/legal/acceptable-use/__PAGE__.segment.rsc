s AUP applies to all access and use of:"}],["$","ul",null,{"children":[["$","li",null,{"children":"The Push web and mobile application at pushnyc.co;"}],["$","li",null,{"children":"The Push API and any integrations built on top of it;"}],["$","li",null,{"children":"Content created, published, or submitted in connection with Push campaigns, including content posted on third-party platforms (Instagram, TikTok, YouTube) that references or promotes a Push-attributed campaign;"}],["$","li",null,{"children":"QR codes, attribution links, and campaign materials generated by the Platform; and"}],["$","li",null,{"children":"Any communication conducted through Push-provided messaging features."}]]}],["$","p",null,{"children":"This policy applies regardless of whether access occurs via browser, mobile app, API, or any other interface."}],["$","hr",null,{"className":"legal-divider"}],["$","h2",null,{"id":"s2","className":"legal-section-heading","children":[["$","span",null,{"className":"legal-section-heading__number","children":"02 /"}],"Attribution Integrity"]}],["$","p",null,{"children":"The integrity of QR attribution data is foundational to the Push platform. Any attempt to artificially inflate, manipulate, or misrepresent Attribution Events is a serious violation. Prohibited conduct includes but is not limited to:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Using bots, scripts, automated tools, or emulators to generate QR scans;"}],["$","li",null,{"children":"Employing click farms, paid scan services, or any form of organized inauthentic scanning;"}],["$","li",null,{"children":"Sharing, transferring, duplicating, or republishing a Creator-specific QR code to any party other than genuine potential customers;"}],["$","li",null,{"children":"Instructing, incentivizing, or coercing individuals to scan QR codes without genuine intent to visit or purchase at the Merchant location;"}],["$","li",null,{"children":"Using VPNs, proxy servers, or IP spoofing to circumvent geographic validation in the attribution engine;"}],["$","li",null,{"children":"Creating fictitious customer visits through any technical or social means;"}],"$L2","$L3"]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31"],null,"$L32"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"jP0DLMf4-wLgFORDq_Yoq"}
2:["$","li",null,{"children":"Colluding with Merchant staff to falsely confirm visits that did not occur; and"}]
3:["$","li",null,{"children":"Submitting false or fabricated campaign performance data in any dispute or reporting context."}]
4:["$","div",null,{"className":"legal-callout","children":["$","p",null,{"children":[["$","strong",null,{"children":"Enforcement:"}],"Push operates a real-time anti-fraud engine that monitors scan velocity, device fingerprint anomalies, GPS cell consistency, and IP reputation. Flagged events are reviewed by our Trust & Safety team within 24 hours. Confirmed fraud results in immediate payout hold, account suspension, and clawback of previously paid earnings."]}]}]
5:["$","hr",null,{"className":"legal-divider"}]
6:["$","h2",null,{"id":"s3","className":"legal-section-heading","children":[["$","span",null,{"className":"legal-section-heading__number","children":"03 /"}],"Content Standards"]}]
7:["$","p",null,{"children":"All Content created in connection with Push campaigns — whether posted on Instagram, TikTok, YouTube, or any other platform — must comply with the following standards:"}]
8:["$","h3",null,{"children":"3.1 Accuracy & Honesty"}]
9:["$","ul",null,{"children":[["$","li",null,{"children":"Content must accurately represent the Merchant's products, services, and offers. False or misleading claims about pricing, availability, quality, or features are prohibited."}],["$","li",null,{"children":"Creators must disclose the paid/sponsored nature of all Campaign content in compliance with FTC guidelines (16 CFR Part 255) and any applicable platform rules. Accepted disclosures include “#ad,” “#sponsored,” or a clearly visible “Paid partnership” tag."}],["$","li",null,{"children":"Creators may not claim personal experience with a product or service they have not genuinely used or visited."}]]}]
a:["$","h3",null,{"children":"3.2 Prohibited Content Categories"}]
b:["$","p",null,{"children":"The following content is strictly prohibited:"}]
c:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Hate speech:"}]," content that promotes violence, discrimination, or dehumanization based on race, ethnicity, national origin, religion, gender, sexual orientation, disability, age, or immigration status;"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Harassment and abuse:"}]," targeted harassment, threats, doxxing, or coordinated campaigns against individuals;"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Sexually explicit content:"}]," nudity or sexual content in any Campaign material;"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Dangerous content:"}]," glorification or instruction in violence, self-harm, eating disorders, or dangerous challenges;"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Illegal products or services:"}]," promotion of illegal firearms, controlled substances (unless licensed), counterfeit goods, or services that violate applicable law;"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Misinformation:"}]," health misinformation, election misinformation, or fabricated news presented as factual;"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Privacy violations:"}]," sharing personal data, private images, or location information of others without consent; and"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Intellectual property infringement:"}]," unauthorized use of copyrighted music, imagery, or brand marks in Campaign content."]}]]}]
d:["$","h3",null,{"children":"3.3 Age-Restricted Categories"}]
e:["$","p",null,{"children":"Campaigns promoting age-restricted products (alcohol, tobacco, cannabis where legal, gambling) are subject to additional restrictions:"}]
f:["$","ul",null,{"children":[["$","li",null,{"children":"Merchants must confirm compliance with applicable New York State licensing requirements before campaign activation;"}],["$","li",null,{"children":"Creators promoting age-restricted products must be 21+ (alcohol, cannabis) or 18+ (tobacco, gambling) and must not target content at underage audiences;"}],["$","li",null,{"children":"Content must include required legal disclaimers (e.g., “Drink responsibly. Must be 21+”); and"}],["$","li",null,{"children":"Platform campaign pages for age-restricted Merchants will display an age-gate interstitial."}]]}]
10:["$","hr",null,{"className":"legal-divider"}]
11:["$","h2",null,{"id":"s4","className":"legal-section-heading","children":[["$","span",null,{"className":"legal-section-heading__number","children":"04 /"}],"Platform Integrity"]}]
12:["$","p",null,{"children":"Users must not take any action that compromises the security, availability, or integrity of the Platform. Prohibited technical conduct includes:"}]
13:["$","ol",null,{"children":[["$","li",null,{"children":"Attempting to gain unauthorized access to any account, system, or network associated with the Platform;"}],["$","li",null,{"children":"Introducing malware, ransomware, spyware, or any other malicious code;"}],["$","li",null,{"children":"Conducting or facilitating denial-of-service (DoS) or distributed denial-of-service (DDoS) attacks;"}],["$","li",null,{"children":"Exploiting vulnerabilities without prior written authorization from Push security (responsible disclosure: security@pushnyc.co);"}],["$","li",null,{"children":"Reverse-engineering, decompiling, or disassembling any part of the Platform software or QR attribution system;"}],["$","li",null,{"children":"Scraping, harvesting, or systematically extracting data from the Platform without a valid API authorization;"}],["$","li",null,{"children":"Circumventing rate limits, access controls, or IP-based restrictions; and"}],["$","li",null,{"children":"Impersonating Push infrastructure, endpoints, or security certificates."}]]}]
