13:["$","p",null,{"children":["On your first visit to pushnyc.co, you will see a cookie consent banner. You may accept all cookies, accept only strictly necessary cookies, or customise your preferences by category. Your choice is saved in the"," ",["$","code",null,{"children":"push_consent"}],"cookie for 12 months. You can change your preference at any time via the “Cookie Preferences” link in the site footer."]}]
14:["$","h3",null,{"children":"4.2 Browser Settings"}]
15:["$","p",null,{"children":"Most browsers allow you to control cookies via settings. You can block all cookies, delete existing cookies, or be notified before cookies are set. Common browser controls:"}]
16:["$","ul",null,{"children":[["$","li",null,{"children":"Chrome: Settings → Privacy and security → Cookies and other site data"}],["$","li",null,{"children":"Firefox: Settings → Privacy & Security → Cookies and Site Data"}],["$","li",null,{"children":"Safari: Preferences → Privacy → Manage Website Data"}],["$","li",null,{"children":"Edge: Settings → Cookies and site permissions"}]]}]
17:["$","p",null,{"children":"Note that blocking strictly necessary cookies will prevent the Platform from functioning correctly."}]
18:["$","h3",null,{"children":"4.3 Do Not Track"}]
19:["$","p",null,{"children":["We respect the ",["$","code",null,{"children":"DNT"}]," (Do Not Track) browser signal by disabling PostHog analytics for sessions where DNT is enabled. Strictly necessary and security cookies are unaffected by DNT."]}]
