1e:["$","p",null,{"children":["For users in the European Economic Area and United Kingdom, our use of non-essential cookies is based on your ",["$","strong",null,{"children":"consent"}]," (GDPR Article 6(1)(a) and ePrivacy Directive Article 5(3)). Strictly necessary and security cookies are placed on the basis of"," ",["$","strong",null,{"children":"legitimate interests"}]," (fraud prevention and platform security) without requiring consent."]}]
1f:["$","p",null,{"children":"You have the right to withdraw consent at any time without affecting the lawfulness of processing before withdrawal. Use the cookie preferences centre or browser settings to do so."}]
