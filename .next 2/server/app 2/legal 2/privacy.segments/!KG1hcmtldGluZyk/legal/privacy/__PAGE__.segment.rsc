",null,{"children":"Push"}],",\" \"",["$","strong",null,{"children":"we"}],",\" \"",["$","strong",null,{"children":"us"}],"\") is a Delaware corporation headquartered in New York City, NY 10001. We operate a software-as-a-service platform that connects local businesses ( \"",["$","strong",null,{"children":"Merchants"}],"\") with content creators ( \"",["$","strong",null,{"children":"Creators"}],"\") to drive foot-traffic through QR-code attribution technology."]}],["$","p",null,{"children":["For users in the European Economic Area and United Kingdom, Push NYC, Inc. acts as the ",["$","strong",null,{"children":"data controller"}]," under the General Data Protection Regulation (GDPR) and UK GDPR. For California residents, we comply with the California Consumer Privacy Act (CCPA) as amended by the California Privacy Rights Act (CPRA)."]}],["$","p",null,{"children":["Our designated ",["$","strong",null,{"children":"Data Protection Officer (DPO)"}]," can be reached at"," ",["$","a",null,{"href":"mailto:privacy@pushnyc.co","style":{"color":"var(--tertiary)"},"children":"privacy@pushnyc.co"}]," ","or by post at Push NYC, Inc., Attn: Privacy, 28 West 23rd St, New York, NY 10010."]}],["$","hr",null,{"className":"legal-divider"}],["$","h2",null,{"id":"s2","className":"legal-section-heading","children":[["$","span",null,{"className":"legal-section-heading__number","children":"02 /"}],"Key Definitions"]}],["$","dl",null,{"children":[["$","dt",null,{"children":"Platform"}],["$","dd",null,{"children":"The Push web application, mobile application, APIs, and associated services available at pushnyc.co and affiliated subdomains."}],["$","dt",null,{"children":"Creator"}],["$","dd",null,{"children":"An individual who signs up to the Platform under any of the six Creator tiers (Nano through Legend) and generates content promoting Merchant campaigns."}],["$","dt",null,{"children":"Merchant"}],["$","dd",null,{"children":"A business entity that subscribes to Push under the Starter, Growth, or Pro plan to run performance-based marketing campaigns."}],["$","dt",null,{"children":"QR Attribution Event"}],["$","dd",null,{"children":"A recorded scan of a Push-generated QR code that links a customer visit or purchase to a specific Creator and Campaign."}],"$L2","$L3","$L4","$L5"]}],"$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41","$L42","$L43","$L44"],null,"$L45"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"jP0DLMf4-wLgFORDq_Yoq"}
