23:["$","p",null,{"children":"Push implements technical and organizational measures appropriate to the risk, including:"}]
24:["$","ul",null,{"children":[["$","li",null,{"children":"TLS 1.3 encryption in transit; AES-256 encryption at rest for all database volumes."}],["$","li",null,{"children":"Role-based access control (RBAC) with principle of least privilege; MFA required for all engineering and operations staff."}],["$","li",null,{"children":"Regular penetration testing (minimum annual, performed by a qualified third party) and vulnerability scanning (weekly automated)."}],["$","li",null,{"children":"SOC 2 Type II audit in progress; expected completion Q3 2026. Until then, we share our security posture summary on request."}],["$","li",null,{"children":"Anti-fraud engine monitoring QR scan velocity, device fingerprint anomalies, and GPS/IP inconsistencies in real time."}]]}]
25:["$","p",null,{"children":"No system is 100% secure. In the event of a data breach affecting your personal data, we will notify affected users and relevant supervisory authorities within 72 hours of discovery, as required by GDPR Article 33."}]
