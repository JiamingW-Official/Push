a:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Account registration:"}]," name, email address, phone number, username, profile photo, borough/neighborhood (NYC), and tier preference."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Creator profile:"}]," social media handles (Instagram, TikTok, YouTube), follower count, content categories, and payment details (processed via Stripe; we do not store raw card numbers)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Merchant profile:"}]," business name, EIN/tax ID, physical address, operating hours, and Stripe merchant account information."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communications:"}]," messages exchanged with our support team, in-app messaging between Merchants and Creators, and survey responses."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Compliance documents:"}]," government-issued ID and W-9/W-8BEN forms collected to satisfy IRS 1099 reporting obligations for Creators earning above $600 USD annually."]}]]}]
