1c:["$","p",null,{"children":"Push stores primary data in the United States (AWS us-east-1, N. Virginia). For users in the EEA, UK, or Switzerland, data transfers to the US are governed by the EU-US Data Privacy Framework where applicable, or by Standard Contractual Clauses (SCCs, Commission Decision 2021/914) incorporated into our DPAs with sub-processors."}]
1d:["$","p",null,{"children":"Analytics data processed by PostHog is stored in EU data centers (eu.posthog.com). Transactional emails processed by Resend use US infrastructure; only email address and template payload are transferred."}]
