3d:["$","p",null,{"children":"We may update this Privacy Policy from time to time. When we make material changes, we will notify you by email (to your registered address) and post a prominent notice on the Platform at least 14 days before the changes take effect. Your continued use of the Platform after the effective date constitutes acceptance of the revised policy."}]
3e:["$","p",null,{"children":"Non-material changes (typo corrections, clarifications that do not alter rights or obligations) may be made without advance notice; the “Last updated” date will always reflect the most recent revision."}]
3f:["$","p",null,{"children":"Previous versions of this policy are available on request from our DPO."}]
