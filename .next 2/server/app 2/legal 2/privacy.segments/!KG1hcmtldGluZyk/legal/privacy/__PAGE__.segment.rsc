28:["$","p",null,{"children":"Depending on your jurisdiction, you may have the following rights:"}]
29:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Access (GDPR Art. 15 / CCPA §1798.110):"}]," request a copy of the personal data we hold about you."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Rectification (GDPR Art. 16):"}]," correct inaccurate data."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Erasure (GDPR Art. 17 / CCPA §1798.105):"}]," request deletion of your personal data, subject to retention obligations."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Restriction (GDPR Art. 18):"}]," limit processing in certain circumstances."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Portability (GDPR Art. 20):"}]," receive your data in a structured, machine-readable format."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Objection (GDPR Art. 21):"}]," object to processing based on legitimate interests."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Opt-out of sale/sharing (CCPA):"}]," California residents may opt out via the \"Do Not Sell or Share My Personal Information\" link in the footer. We do not sell data; this right is included for completeness."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Withdraw consent:"}]," at any time, without affecting lawfulness of prior processing."]}]]}]
2a:["$","p",null,{"children":["To exercise any right, email"," ",["$","a",null,{"href":"mailto:privacy@pushnyc.co","style":{"color":"var(--tertiary)"},"children":"privacy@pushnyc.co"}]," ","from your registered account email. We respond within 30 days (GDPR) or 45 days (CCPA). Identity verification is required before we can action a request."]}]
