15:["$","ol",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Service delivery:"}]," matching Creators to Merchant campaigns, generating and tracking QR codes, processing payouts, and generating performance dashboards."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Attribution verification:"}]," validating QR Attribution Events to confirm legitimate customer visits and prevent fraudulent scan inflation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Payout processing:"}]," calculating Creator earnings based on verified campaign metrics, releasing funds via Stripe, and generating tax documentation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Product improvement:"}]," analyzing aggregate, de-identified usage patterns to improve Platform features, ranking algorithms, and Creator-Merchant matching models."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Safety and integrity:"}]," detecting and preventing fraud, abuse, and violations of our Acceptable Use Policy."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communications:"}]," sending transactional emails (campaign live, payout released, account alerts), service updates, and — with your consent — promotional content."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal and regulatory compliance:"}]," responding to valid legal process, maintaining records required by IRS, NY State, and applicable data protection authorities."]}]]}]
