20:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Active account data:"}]," retained for the life of the account plus 7 years for tax record compliance (IRS Rev. Proc. 98-25)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"QR Attribution Events:"}]," raw event logs retained for 3 years; aggregated campaign statistics retained indefinitely for Merchant reporting."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Payout records:"}]," 7 years post-issuance for IRS 1099/MISC compliance."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Closed account data:"}]," personal identifiers deleted within 90 days of account closure, except where retention is required by law."]}],["$","li",null,{"children":[["$","strong",null,{"children":"IP addresses:"}]," truncated to /24 after 30 days; full IP purged after 90 days unless associated with an active fraud investigation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Marketing opt-in records:"}]," retained for 6 years as evidence of consent under GDPR Article 7(1)."]}]]}]
