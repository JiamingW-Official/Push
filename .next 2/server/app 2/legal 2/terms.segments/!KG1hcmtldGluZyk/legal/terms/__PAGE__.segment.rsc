23:["$","h3",null,{"children":"5.1 Subscription Plans"}]
24:["$","p",null,{"children":"Push offers three subscription tiers: Starter ($19.99/month), Growth ($69/month), and Pro ($199/month). Plan features, campaign limits, and Creator tier access are as specified on the pricing page at the time of subscription. Push reserves the right to modify plan pricing with 30 days' advance notice to existing subscribers."}]
25:["$","p",null,{"children":"Subscriptions are billed monthly on the anniversary of the subscription date via Stripe. All fees are in USD. Failure to maintain a valid payment method may result in service suspension."}]
26:["$","h3",null,{"children":"5.2 Campaign Creation & Management"}]
27:["$","p",null,{"children":"Merchants are responsible for:"}]
28:["$","ul",null,{"children":[["$","li",null,{"children":"Defining accurate campaign briefs, including product/service descriptions, eligible Creators, payout structure, attribution window, and brand guidelines."}],["$","li",null,{"children":"Ensuring that campaign terms comply with applicable advertising law, including FTC guidelines, New York State truth-in-advertising requirements, and industry-specific regulations (e.g., alcohol, food service)."}],["$","li",null,{"children":"Maintaining sufficient funds in the campaign budget. Push will pause a Campaign automatically if projected payout obligations exceed the committed budget."}],["$","li",null,{"children":"Providing timely feedback on Creator content submissions within the review window (48 hours unless otherwise specified)."}]]}]
29:["$","h3",null,{"children":"5.3 Attribution Acceptance"}]
2a:["$","p",null,{"children":"Merchants accept that Push attribution data is the authoritative source for payout calculations. Merchants may dispute individual Attribution Events within 7 days of a Campaign closing report, providing documentary evidence of the alleged inaccuracy. Push will review disputes within 10 business days and issue a final determination. Payout adjustments resulting from upheld disputes will be applied to the next billing cycle."}]
2b:["$","h3",null,{"children":"5.4 Merchant Conduct"}]
2c:["$","p",null,{"children":"Merchants may not: contact Creators outside the Platform to circumvent fees; require Creators to make personal purchases as a condition of participation; discriminate against Creators on protected grounds; or request Content that violates our Acceptable Use Policy."}]
2d:["$","hr",null,{"className":"legal-divider"}]
2e:["$","h2",null,{"id":"s6","className":"legal-section-heading","children":[["$","span",null,{"className":"legal-section-heading__number","children":"06 /"}],"Prohibited Conduct"]}]
2f:["$","p",null,{"children":"In addition to obligations in the Acceptable Use Policy, you must not:"}]
30:["$","ol",null,{"children":[["$","li",null,{"children":"Reverse-engineer, decompile, or disassemble any part of the Platform or its QR attribution algorithms."}],["$","li",null,{"children":"Scrape, crawl, or extract data from the Platform using automated means without written authorization."}],["$","li",null,{"children":"Interfere with the integrity, security, or availability of the Platform, including DDoS attacks, SQL injection, or cross-site scripting."}],["$","li",null,{"children":"Circumvent any rate limits, access controls, or technical protection measures."}],["$","li",null,{"children":"Use the Platform to violate any applicable law or regulation, including securities law, privacy law, or consumer protection law."}],["$","li",null,{"children":"Impersonate Push, a Merchant, a Creator, or any other person or entity."}],["$","li",null,{"children":"Use Campaign materials or QR codes for any purpose other than the specified Campaign."}],["$","li",null,{"children":"Engage in or facilitate any form of artificial scan inflation, including via bots, VPNs, proxy networks, or coordinated human effort."}]]}]
31:["$","p",null,{"children":"Violation of any of the above is grounds for immediate account suspension and may result in legal action, including claims for damages under the Computer Fraud and Abuse Act (18 U.S.C. § 1030) and applicable state law."}]
