d:["$","h2",null,{"id":"s3","className":"legal-section-heading","children":[["$","span",null,{"className":"legal-section-heading__number","children":"03 /"}],"Eligibility & Account Registration"]}]
e:["$","p",null,{"children":"You must meet the following requirements to use the Platform:"}]
f:["$","ul",null,{"children":[["$","li",null,{"children":["You must be at least ",["$","strong",null,{"children":"18 years of age"}],". The Platform is not available to minors."]}],["$","li",null,{"children":"You must have legal capacity to enter into a binding contract under the laws of your jurisdiction."}],["$","li",null,{"children":"Your use must not be prohibited by applicable law (including US export controls and sanctions lists)."}],["$","li",null,{"children":"Creators must have an active, publicly visible social media presence on at least one supported platform (Instagram, TikTok, or YouTube) at the time of registration."}],["$","li",null,{"children":"Merchants must have a valid US business registration and a physical business location in the New York City metropolitan area (the five boroughs, or Nassau, Suffolk, or Westchester counties)."}]]}]
10:["$","h3",null,{"children":"Account Security"}]
11:["$","p",null,{"children":["You are responsible for maintaining the confidentiality of your account credentials. You must notify us immediately at"," ",["$","a",null,{"href":"mailto:security@pushnyc.co","style":{"color":"var(--tertiary)"},"children":"security@pushnyc.co"}]," ","if you suspect unauthorized access. Push is not liable for losses resulting from unauthorized account access where you failed to maintain adequate credential security."]}]
12:["$","p",null,{"children":"You may not create more than one account per person or entity without our prior written consent. Duplicate accounts are grounds for immediate suspension."}]
