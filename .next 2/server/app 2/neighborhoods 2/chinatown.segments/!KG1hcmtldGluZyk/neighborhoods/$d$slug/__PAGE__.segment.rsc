2:T8f4,[{"@context":"https://schema.org","@type":"Place","name":"Chinatown","description":"Manhattan's Chinatown is one of the oldest and most densely populated Chinese communities in the Western Hemisphere — a neighborhood that has maintained its character through waves of change that have","url":"https://withpush.co/neighborhoods/chinatown","geo":{"@type":"GeoCoordinates","latitude":40.7158,"longitude":-73.997},"address":{"@type":"PostalAddress","addressLocality":"Chinatown","addressRegion":"NY","addressCountry":"US"},"containedInPlace":{"@type":"City","name":"New York City"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does Push work in Chinatown?","acceptedAnswer":{"@type":"Answer","text":"Push connects local creators with merchants in Chinatown, Manhattan. Creators visit participating businesses, scan a QR code to verify their visit, then publish content. Merchants pay only for verified foot traffic — no guessing required."}},{"@type":"Question","name":"How many campaigns are active in Chinatown right now?","acceptedAnswer":{"@type":"Answer","text":"Chinatown currently has 17 active creator campaigns across 21 merchants, with 76 creators operating in this neighborhood."}},{"@type":"Question","name":"What is the average campaign payout in Chinatown?","acceptedAnswer":{"@type":"Answer","text":"The average campaign payout in Chinatown is $27 per verified visit. Total verified visits in this neighborhood have reached 2,109."}}]},{"@context":"https://schema.org","@type":"ItemList","name":"Featured Merchants in Chinatown","numberOfItems":3,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"LocalBusiness","name":"Nom Wah Tea Parlor","address":"13 Doyers St, New York, NY 10013","description":"Food & Drink business in Chinatown with 1 active Push campaign."}},{"@type":"ListItem","position":2,"item":{"@type":"LocalBusiness","name":"Xi'an Famous Foods","address":"81 St Marks Pl, New York, NY 10003","description":"Food & Drink business in Chinatown with 2 active Push campaigns."}},{"@type":"ListItem","position":3,"item":{"@type":"LocalBusiness","name":"Fong On","address":"81 Division St, New York, NY 10002","description":"Specialty Food business in Chinatown with 1 active Push campaign."}}]}]0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","main",null,{"className":"nh-page","children":[["$","section",null,{"className":"nhd-hero","children":["$","div",null,{"className":"container nhd-hero-inner","children":[["$","nav",null,{"className":"nhd-breadcrumb","aria-label":"Breadcrumb","children":[["$","$L3",null,{"href":"/","children":"Push"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","$L3",null,{"href":"/neighborhoods","children":"Neighborhoods"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","span",null,{"style":{"color":"rgba(245,242,236,0.75)"},"children":"Chinatown"}]]}],["$","p",null,{"className":"nhd-hero-borough","children":"Manhattan"}],["$","h1",null,{"className":"nhd-hero-name","children":"Chinatown"}],["$","p",null,{"className":"nhd-hero-desc","children":"Manhattan's Chinatown is one of the oldest and most densely populated Chinese communities in the Western Hemisphere — a neighborhood that has maintained its character through waves of change that have transformed every surrounding area. Canal Street and Mott Street are the commercial arteries: fish markets, produce vendors, bakeries, dim sum halls, and herbal medicine shops operating at a pace and density that feels more like Hong Kong than Manhattan. The dining options are extraordinary in value and variety — some of the best food in New York City at prices that feel like a different city. Push campaigns in Chinatown serve a predominantly local audience and are calibrated accordingly: campaign payouts are lower, but the foot traffic verification model is highly valued by merchants who have historically had limited access to measurable marketing tools. Creator campaigns that document Chinatown authentically — the market culture, the food, the social fabric — perform best on the platform."}]]}]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb"]}]],["$Lc","$Ld"],"$Le"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"jP0DLMf4-wLgFORDq_Yoq"}
