cription":"Food & Drink business in Greenpoint with 1 active Push campaign."}},{"@type":"ListItem","position":3,"item":{"@type":"LocalBusiness","name":"Champion Coffee","address":"142 Nassau Ave, Brooklyn, NY 11222","description":"Coffee business in Greenpoint with 2 active Push campaigns."}}]}]0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","main",null,{"className":"nh-page","children":[["$","section",null,{"className":"nhd-hero","children":["$","div",null,{"className":"container nhd-hero-inner","children":[["$","nav",null,{"className":"nhd-breadcrumb","aria-label":"Breadcrumb","children":[["$","$L3",null,{"href":"/","children":"Push"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","$L3",null,{"href":"/neighborhoods","children":"Neighborhoods"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","span",null,{"style":{"color":"rgba(245,242,236,0.75)"},"children":"Greenpoint"}]]}],["$","p",null,{"className":"nhd-hero-borough","children":"Brooklyn"}],["$","h1",null,{"className":"nhd-hero-name","children":"Greenpoint"}],["$","p",null,{"className":"nhd-hero-desc","children":"Greenpoint is Brooklyn's northernmost neighborhood — a tight-knit, historically Polish community that has absorbed a creative class without losing its character. Manhattan Avenue is still lined with pierogi shops, Polish delis, and Catholic churches alongside independent coffee bars, natural wine shops, and the occasional gallery. The neighborhood sits along Newtown Creek and the East River, and its industrial waterfront has been transformed into parks and cultural spaces. Push operates in Greenpoint with particular success in food, coffee, and artisan categories — the neighborhood's residents are sophisticated consumers who value provenance and craft. Creator campaigns here perform best when they lean into the neighborhood's dual identity: old-world Polish charm and new-world Brooklyn creative. The cross-pollination is authentic and visually rich, making Greenpoint one of Push's highest-performing neighborhoods for content quality metrics."}]]}]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb"]}]],["$Lc","$Ld"],"$Le"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"jP0DLMf4-wLgFORDq_Yoq"}
