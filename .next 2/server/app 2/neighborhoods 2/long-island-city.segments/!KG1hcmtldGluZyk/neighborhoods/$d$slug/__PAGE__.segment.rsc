2:T966,[{"@context":"https://schema.org","@type":"Place","name":"Long Island City","description":"Long Island City has transformed faster than perhaps any neighborhood in New York over the past two decades — from industrial wasteland to a waterfront district of luxury towers, corporate offices, an","url":"https://withpush.co/neighborhoods/long-island-city","geo":{"@type":"GeoCoordinates","latitude":40.7447,"longitude":-73.9485},"address":{"@type":"PostalAddress","addressLocality":"Long Island City","addressRegion":"NY","addressCountry":"US"},"containedInPlace":{"@type":"City","name":"New York City"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does Push work in Long Island City?","acceptedAnswer":{"@type":"Answer","text":"Push connects local creators with merchants in Long Island City, Queens. Creators visit participating businesses, scan a QR code to verify their visit, then publish content. Merchants pay only for verified foot traffic — no guessing required."}},{"@type":"Question","name":"How many campaigns are active in Long Island City right now?","acceptedAnswer":{"@type":"Answer","text":"Long Island City currently has 17 active creator campaigns across 22 merchants, with 79 creators operating in this neighborhood."}},{"@type":"Question","name":"What is the average campaign payout in Long Island City?","acceptedAnswer":{"@type":"Answer","text":"The average campaign payout in Long Island City is $48 per verified visit. Total verified visits in this neighborhood have reached 2,134."}}]},{"@context":"https://schema.org","@type":"ItemList","name":"Featured Merchants in Long Island City","numberOfItems":3,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"LocalBusiness","name":"Sweetleaf Coffee LIC","address":"10-93 Jackson Ave, Long Island City, NY 11101","description":"Coffee business in Long Island City with 2 active Push campaigns."}},{"@type":"ListItem","position":2,"item":{"@type":"LocalBusiness","name":"Dutch Kills Bar","address":"27-24 Jackson Ave, Long Island City, NY 11101","description":"Nightlife business in Long Island City with 1 active Push campaign."}},{"@type":"ListItem","position":3,"item":{"@type":"LocalBusiness","name":"Casa Enrique","address":"5-48 49th Ave, Long Island City, NY 11101","description":"Food & Drink business in Long Island City with 2 active Push campaigns."}}]}]0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","main",null,{"className":"nh-page","children":[["$","section",null,{"className":"nhd-hero","children":["$","div",null,{"className":"container nhd-hero-inner","children":[["$","nav",null,{"className":"nhd-breadcrumb","aria-label":"Breadcrumb","children":[["$","$L3",null,{"href":"/","children":"Push"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","$L3",null,{"href":"/neighborhoods","children":"Neighborhoods"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","span",null,{"style":{"color":"rgba(245,242,236,0.75)"},"children":"Long Island City"}]]}],["$","p",null,{"className":"nhd-hero-borough","children":"Queens"}],["$","h1",null,{"className":"nhd-hero-name","children":"Long Island City"}],["$","p",null,{"className":"nhd-hero-desc","children":"Long Island City has transformed faster than perhaps any neighborhood in New York over the past two decades — from industrial wasteland to a waterfront district of luxury towers, corporate offices, and a surprisingly vibrant arts and dining scene. The view of the Manhattan skyline from Hunter's Point South Park is one of the best in the city, and the neighborhood's MoMA PS1 branch is a world-class contemporary art institution. Push operates in LIC with a mix of residential dining campaigns and the growing brunch and café scene that serves the neighborhood's younger professional population. The neighborhood's waterfront parks make it an unusual setting for campaign content — outdoor dining, weekend picnics, and waterfront bars provide a visual language distinct from any other Queens neighborhood. Creator campaigns in LIC tend toward lifestyle and food categories, with fitness studios serving the building-heavy residential blocks also running consistent Push campaigns."}]]}]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb"]}]],["$Lc","$Ld"],"$Le"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"jP0DLMf4-wLgFORDq_Yoq"}
