2:T8eb,[{"@context":"https://schema.org","@type":"Place","name":"Mott Haven","description":"Mott Haven sits at the southernmost tip of the Bronx, across the Harlem River from East Harlem, and has become one of New York's most discussed emerging neighborhoods. The neighborhood's Port Morris i","url":"https://withpush.co/neighborhoods/mott-haven","geo":{"@type":"GeoCoordinates","latitude":40.8074,"longitude":-73.9262},"address":{"@type":"PostalAddress","addressLocality":"Mott Haven","addressRegion":"NY","addressCountry":"US"},"containedInPlace":{"@type":"City","name":"New York City"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does Push work in Mott Haven?","acceptedAnswer":{"@type":"Answer","text":"Push connects local creators with merchants in Mott Haven, Bronx. Creators visit participating businesses, scan a QR code to verify their visit, then publish content. Merchants pay only for verified foot traffic — no guessing required."}},{"@type":"Question","name":"How many campaigns are active in Mott Haven right now?","acceptedAnswer":{"@type":"Answer","text":"Mott Haven currently has 10 active creator campaigns across 13 merchants, with 46 creators operating in this neighborhood."}},{"@type":"Question","name":"What is the average campaign payout in Mott Haven?","acceptedAnswer":{"@type":"Answer","text":"The average campaign payout in Mott Haven is $32 per verified visit. Total verified visits in this neighborhood have reached 1,234."}}]},{"@context":"https://schema.org","@type":"ItemList","name":"Featured Merchants in Mott Haven","numberOfItems":3,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"LocalBusiness","name":"St. Anns Warehouse","address":"29 Jay St, Brooklyn, NY 11201","description":"Lifestyle business in Mott Haven with 1 active Push campaign."}},{"@type":"ListItem","position":2,"item":{"@type":"LocalBusiness","name":"The Bruckner Bar","address":"1 Bruckner Blvd, Bronx, NY 10454","description":"Nightlife business in Mott Haven with 2 active Push campaigns."}},{"@type":"ListItem","position":3,"item":{"@type":"LocalBusiness","name":"Beatstro","address":"428 E 141st St, Bronx, NY 10454","description":"Food & Drink business in Mott Haven with 1 active Push campaign."}}]}]0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","main",null,{"className":"nh-page","children":[["$","section",null,{"className":"nhd-hero","children":["$","div",null,{"className":"container nhd-hero-inner","children":[["$","nav",null,{"className":"nhd-breadcrumb","aria-label":"Breadcrumb","children":[["$","$L3",null,{"href":"/","children":"Push"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","$L3",null,{"href":"/neighborhoods","children":"Neighborhoods"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","span",null,{"style":{"color":"rgba(245,242,236,0.75)"},"children":"Mott Haven"}]]}],["$","p",null,{"className":"nhd-hero-borough","children":"Bronx"}],["$","h1",null,{"className":"nhd-hero-name","children":"Mott Haven"}],["$","p",null,{"className":"nhd-hero-desc","children":"Mott Haven sits at the southernmost tip of the Bronx, across the Harlem River from East Harlem, and has become one of New York's most discussed emerging neighborhoods. The neighborhood's Port Morris industrial section, along the East River waterfront, has attracted artists, makers, and a growing number of destination restaurants and bars that have established Mott Haven as a legitimate dining destination for the first time. Push operates here at early-stage density — merchant adoption is growing, and the creator community is enthusiastic about documenting a neighborhood in transition. The South Bronx heritage is present in the neighborhood's character: resilient, community-focused, fiercely proud. Campaigns that honor that identity rather than instrumentalizing the neighborhood's 'emergence narrative' perform best on Push here. Top categories: Latin American food, craft bars, art studios, and fitness."}]]}]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb"]}]],["$Lc","$Ld"],"$Le"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"jP0DLMf4-wLgFORDq_Yoq"}
