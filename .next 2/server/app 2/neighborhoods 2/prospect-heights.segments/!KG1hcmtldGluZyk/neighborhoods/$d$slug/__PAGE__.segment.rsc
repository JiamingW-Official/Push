2:T942,[{"@context":"https://schema.org","@type":"Place","name":"Prospect Heights","description":"Prospect Heights sits between Park Slope and Crown Heights, borrowing the best qualities of both — the leafy residential streets and dining quality of the former, the cultural diversity and energy of ","url":"https://withpush.co/neighborhoods/prospect-heights","geo":{"@type":"GeoCoordinates","latitude":40.6771,"longitude":-73.9638},"address":{"@type":"PostalAddress","addressLocality":"Prospect Heights","addressRegion":"NY","addressCountry":"US"},"containedInPlace":{"@type":"City","name":"New York City"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does Push work in Prospect Heights?","acceptedAnswer":{"@type":"Answer","text":"Push connects local creators with merchants in Prospect Heights, Brooklyn. Creators visit participating businesses, scan a QR code to verify their visit, then publish content. Merchants pay only for verified foot traffic — no guessing required."}},{"@type":"Question","name":"How many campaigns are active in Prospect Heights right now?","acceptedAnswer":{"@type":"Answer","text":"Prospect Heights currently has 20 active creator campaigns across 26 merchants, with 91 creators operating in this neighborhood."}},{"@type":"Question","name":"What is the average campaign payout in Prospect Heights?","acceptedAnswer":{"@type":"Answer","text":"The average campaign payout in Prospect Heights is $52 per verified visit. Total verified visits in this neighborhood have reached 2,489."}}]},{"@context":"https://schema.org","@type":"ItemList","name":"Featured Merchants in Prospect Heights","numberOfItems":3,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"LocalBusiness","name":"Oxalis","address":"791 Washington Ave, Brooklyn, NY 11238","description":"Food & Drink business in Prospect Heights with 1 active Push campaign."}},{"@type":"ListItem","position":2,"item":{"@type":"LocalBusiness","name":