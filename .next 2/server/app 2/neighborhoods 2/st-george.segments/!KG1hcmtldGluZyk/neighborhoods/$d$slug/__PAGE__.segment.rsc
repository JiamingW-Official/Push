2:T91a,[{"@context":"https://schema.org","@type":"Place","name":"St. George","description":"St. George is Staten Island's most dynamic neighborhood — the ferry terminal district that connects the borough to Manhattan and has become the hub of Staten Island's creative and culinary renaissance","url":"https://withpush.co/neighborhoods/st-george","geo":{"@type":"GeoCoordinates","latitude":40.6437,"longitude":-74.0739},"address":{"@type":"PostalAddress","addressLocality":"St. George","addressRegion":"NY","addressCountry":"US"},"containedInPlace":{"@type":"City","name":"New York City"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does Push work in St. George?","acceptedAnswer":{"@type":"Answer","text":"Push connects local creators with merchants in St. George, Staten Island. Creators visit participating businesses, scan a QR code to verify their visit, then publish content. Merchants pay only for verified foot traffic — no guessing required."}},{"@type":"Question","name":"How many campaigns are active in St. George right now?","acceptedAnswer":{"@type":"Answer","text":"St. George currently has 8 active creator campaigns across 11 merchants, with 36 creators operating in this neighborhood."}},{"@type":"Question","name":"What is the average campaign payout in St. George?","acceptedAnswer":{"@type":"Answer","text":"The average campaign payout in St. George is $33 per verified visit. Total verified visits in this neighborhood have reached 987."}}]},{"@context":"https://schema.org","@type":"ItemList","name":"Featured Merchants in St. George","numberOfItems":3,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"LocalBusiness","name":"Flagship Brewery","address":"40 Minthorne St, Staten Island, NY 10301","description":"Nightlife business in St. George with 2 active Push campaigns."}},{"@type":"ListItem","position":2,"item":{"@type":"LocalBusiness","name":"Vida","address":"381 Van Duzer St, Staten Island, NY 1