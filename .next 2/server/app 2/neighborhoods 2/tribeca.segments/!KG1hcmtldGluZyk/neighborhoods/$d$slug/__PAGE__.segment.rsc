2:T8d8,[{"@context":"https://schema.org","@type":"Place","name":"Tribeca","description":"Tribeca — the Triangle Below Canal — is Manhattan's most expensive residential neighborhood and home to a restaurant scene that consistently produces James Beard Award winners and the city's most soug","url":"https://withpush.co/neighborhoods/tribeca","geo":{"@type":"GeoCoordinates","latitude":40.7195,"longitude":-74.0089},"address":{"@type":"PostalAddress","addressLocality":"Tribeca","addressRegion":"NY","addressCountry":"US"},"containedInPlace":{"@type":"City","name":"New York City"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does Push work in Tribeca?","acceptedAnswer":{"@type":"Answer","text":"Push connects local creators with merchants in Tribeca, Manhattan. Creators visit participating businesses, scan a QR code to verify their visit, then publish content. Merchants pay only for verified foot traffic — no guessing required."}},{"@type":"Question","name":"How many campaigns are active in Tribeca right now?","acceptedAnswer":{"@type":"Answer","text":"Tribeca currently has 22 active creator campaigns across 29 merchants, with 101 creators operating in this neighborhood."}},{"@type":"Question","name":"What is the average campaign payout in Tribeca?","acceptedAnswer":{"@type":"Answer","text":"The average campaign payout in Tribeca is $82 per verified visit. Total verified visits in this neighborhood have reached 2,788."}}]},{"@context":"https://schema.org","@type":"ItemList","name":"Featured Merchants in Tribeca","numberOfItems":3,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"LocalBusiness","name":"Nobu New York","address":"105 Hudson St, New York, NY 10013","description":"Food & Drink business in Tribeca with 1 active Push campaign."}},{"@type":"ListItem","position":2,"item":{"@type":"LocalBusiness","name":"Locanda Verde","address":"377 Greenwich St, New York, NY 10013","description":"Food & Drink business in Tribeca with 2 active Push campaigns."}},{"@type":"ListItem","position":3,"item":{"@type":"LocalBusiness","name":"Frenchette","address":"241 W Broadway, New York, NY 10013","description":"Food & Drink business in Tribeca with 1 active Push campaign."}}]}]0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","main",null,{"className":"nh-page","children":[["$","section",null,{"className":"nhd-hero","children":["$","div",null,{"className":"container nhd-hero-inner","children":[["$","nav",null,{"className":"nhd-breadcrumb","aria-label":"Breadcrumb","children":[["$","$L3",null,{"href":"/","children":"Push"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","$L3",null,{"href":"/neighborhoods","children":"Neighborhoods"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","span",null,{"style":{"color":"rgba(245,242,236,0.75)"},"children":"Tribeca"}]]}],["$","p",null,{"className":"nhd-hero-borough","children":"Manhattan"}],["$","h1",null,{"className":"nhd-hero-name","children":"Tribeca"}],["$","p",null,{"className":"nhd-hero-desc","children":"Tribeca — the Triangle Below Canal — is Manhattan's most expensive residential neighborhood and home to a restaurant scene that consistently produces James Beard Award winners and the city's most sought-after reservations. The neighborhood's cast-iron loft buildings have been converted into some of the most valuable real estate in the world, and the residents who live here expect (and fund) hospitality of a corresponding quality. The Tribeca Film Festival has given the neighborhood a cultural identity to match its commercial one. Push campaigns in Tribeca operate at the premium end of the platform's market — merchants here are selective about creator partnerships, preferring quality and fit over reach metrics. Average campaign payouts are among Push's highest. Creators who work in Tribeca typically have established portfolios and a visual aesthetic that matches the neighborhood's refined character."}]]}]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb"]}]],["$Lc","$Ld"],"$Le"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"jP0DLMf4-wLgFORDq_Yoq"}
