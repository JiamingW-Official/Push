2:T97b,[{"@context":"https://schema.org","@type":"Place","name":"Washington Heights","description":"Washington Heights is upper Manhattan's Dominican Republic — a neighborhood where Spanish is the first language of commerce and the cultural identity is intensely and proudly Caribbean. Broadway throu","url":"https://withpush.co/neighborhoods/washington-heights","geo":{"@type":"GeoCoordinates","latitude":40.8448,"longitude":-73.9392},"address":{"@type":"PostalAddress","addressLocality":"Washington Heights","addressRegion":"NY","addressCountry":"US"},"containedInPlace":{"@type":"City","name":"New York City"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does Push work in Washington Heights?","acceptedAnswer":{"@type":"Answer","text":"Push connects local creators with merchants in Washington Heights, Manhattan. Creators visit participating businesses, scan a QR code to verify their visit, then publish content. Merchants pay only for verified foot traffic — no guessing required."}},{"@type":"Question","name":"How many campaigns are active in Washington Heights right now?","acceptedAnswer":{"@type":"Answer","text":"Washington Heights currently has 15 active creator campaigns across 19 merchants, with 68 creators operating in this neighborhood."}},{"@type":"Question","name":"What is the average campaign payout in Washington Heights?","acceptedAnswer":{"@type":"Answer","text":"The average campaign payout in Washington Heights is $29 per verified visit. Total verified visits in this neighborhood have reached 1,876."}}]},{"@context":"https://schema.org","@type":"ItemList","name":"Featured Merchants in Washington Heights","numberOfItems":3,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"LocalBusiness","name":"La Casa Del Mofongo","address":"1447 St Nicholas Ave, New York, NY 10033","description":"Food & Drink business in Washington Heights with 2 active Push campaigns."}},{"@type":"ListItem","position":2,"item":{"@type":"LocalBusiness","name":"Malecon Restaurant","address":"764 Amsterdam Ave, New York, NY 10025","description":"Food & Drink business in Washington Heights with 1 active Push campaign."}},{"@type":"ListItem","position":3,"item":{"@type":"LocalBusiness","name":"Cachapas y Mas","address":"8314 Broadway, Elmhurst, NY 11373","description":"Food & Drink business in Washington Heights with 2 active Push campaigns."}}]}]0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","main",null,{"className":"nh-page","children":[["$","section",null,{"className":"nhd-hero","children":["$","div",null,{"className":"container nhd-hero-inner","children":[["$","nav",null,{"className":"nhd-breadcrumb","aria-label":"Breadcrumb","children":[["$","$L3",null,{"href":"/","children":"Push"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","$L3",null,{"href":"/neighborhoods","children":"Neighborhoods"}],["$","span",null,{"className":"nhd-breadcrumb-sep","children":"/"}],["$","span",null,{"style":{"color":"rgba(245,242,236,0.75)"},"children":"Washington Heights"}]]}],["$","p",null,{"className":"nhd-hero-borough","children":"Manhattan"}],["$","h1",null,{"className":"nhd-hero-name","children":"Washington Heights"}],["$","p",null,{"className":"nhd-hero-desc","children":"Washington Heights is upper Manhattan's Dominican Republic — a neighborhood where Spanish is the first language of commerce and the cultural identity is intensely and proudly Caribbean. Broadway through Washington Heights is a continuous Dominican parade of restaurants, bodegas, salons, and social clubs. The neighborhood's food culture centers on mofongo, sancocho, pernil, and the cafecito culture of small Dominican coffee counters. Push arrived in Washington Heights through relationships with Dominican-owned businesses who understood creator marketing as a tool for community commerce rather than external tourism. The platform here is genuinely local: creators who live in the neighborhood documenting businesses that serve the people who live there. The results are authentic content that resonates powerfully within the community and, increasingly, with broader New York audiences discovering one of the city's most vibrant and under-documented food cultures."}]]}]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb"]}]],["$Lc","$Ld"],"$Le"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"jP0DLMf4-wLgFORDq_Yoq"}
