{
  "name": "push-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint --dir app --dir components --dir lib --dir middleware.ts",
    "check": "npm run typecheck && npm run lint",
    "preflight": "npm run typecheck && npm run build",
    "ship": "npm run typecheck && git push",
    "clean": "rm -rf .next out tsconfig.tsbuildinfo",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run typecheck",
    "pre-push": "npm run typecheck"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@types/leaflet": "^1.9.21",
    "gsap": "^3.14.2",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.21",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "simple-git-hooks": "^2.13.0",
    "typescript": "^5"
  }
}
